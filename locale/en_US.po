# ── Big numbers ───────────────────────────────────────────────────────────
msgid "bignums_questions"
msgstr "Is {nick} a little bit slower than the rest, or just asking too many questions?  {pct}% lines contained a question!"

msgid "bignums_questions_sub"
msgstr "{nick} didn't know that much either. {pct}% of their lines were questions."

msgid "bignums_caps_loud"
msgstr "The loudest one was {nick}, who yelled {pct}% of the time!"

msgid "bignums_caps_loud_sub"
msgstr "Another old yeller was {nick}, who shouted {pct}% of the time!"

msgid "bignums_caps_shift"
msgstr "It seems that {nick}'s shift-key is hanging: {pct}% of the time they wrote UPPERCASE."

msgid "bignums_caps_shift_sub"
msgstr "{nick} just forgot to deactivate their Caps-Lock. They wrote UPPERCASE {pct}% of the time."

msgid "bignums_violent"
msgstr "{nick} is a very aggressive person. They attacked others {count} time."

msgid "bignums_violent_plural"
msgstr "{nick} is a very aggressive person. They attacked others {count} times."

msgid "bignums_violent_sub"
msgstr "{nick} can't control their aggressions, either. They picked on others {count} times."

msgid "bignums_violent_nobody"
msgstr "Nobody beat anyone up. Everybody was friendly."

msgid "bignums_attacked"
msgstr "Poor {nick}, nobody likes them. They were attacked {count} time."

msgid "bignums_attacked_plural"
msgstr "Poor {nick}, nobody likes them. They were attacked {count} times."

msgid "bignums_attacked_sub"
msgstr "{nick} seems to be unliked too. They got beaten {count} times."

msgid "for_example"
msgstr "For example, like this:"

msgid "bignums_happy"
msgstr "{nick} brings happiness to the world. {pct}% of their lines contained smiling faces. :)"

msgid "bignums_happy_sub"
msgstr "{nick} isn't a sad person either, smiling {pct}% of the time."

msgid "bignums_happy_nobody"
msgstr "Nobody smiles in this channel! Cheer up, everyone."

msgid "bignums_sad"
msgstr "{nick} seems to be sad at the moment: {pct}% of their lines contained sad faces. :("

msgid "bignums_sad_sub"
msgstr "{nick} is also a sad person, crying {pct}% of the time."

msgid "bignums_sad_nobody"
msgstr "Nobody is sad in this channel! What a happy channel. :-)"

msgid "bignums_longest_lines"
msgstr "{nick} wrote the longest lines, averaging {avg} letters per line."

msgid "bignums_longest_lines_sub"
msgstr "{channel} average was {avg} letters per line."

msgid "bignums_shortest_lines"
msgstr "{nick} wrote the shortest lines, averaging {avg} characters per line."

msgid "bignums_shortest_lines_sub"
msgstr "{nick} was tight-lipped, too, averaging {avg} characters."

msgid "bignums_words_total"
msgstr "{nick} spoke a total of {count} words!"

msgid "bignums_words_total_sub"
msgstr "{nick}'s faithful follower, {nick2}, didn't speak so much: {count} words."

msgid "bignums_wpl"
msgstr "{nick} wrote an average of {avg} words per line."

msgid "bignums_wpl_sub"
msgstr "Channel average was {avg} words per line."

